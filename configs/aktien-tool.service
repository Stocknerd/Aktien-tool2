[Unit]
Description=Gunicorn instance to serve Aktien-Tool Main App
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/aktien-tool2
Environment="PATH=/home/ubuntu/aktien-tool2/venv/bin"
Environment="FLASK_SECRET_KEY=replace-with-secure-key"
ExecStart=/home/ubuntu/aktien-tool2/venv/bin/gunicorn --workers 3 --bind 127.0.0.1:8000 app:app

[Install]
WantedBy=multi-user.target
